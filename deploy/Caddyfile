# Caddy 配置（版本化参考副本）
# 服务器上仓库 clone 在 /home/code/sky-personal，Caddy 直接服务仓库目录。
# 同步到生效位置：
#   cp deploy/Caddyfile /etc/caddy/Caddyfile && caddy validate --config /etc/caddy/Caddyfile && systemctl reload caddy

# 80 端口（IP 直连）：根=作品集，/me=个人主页，/sky-tool=Sky 工具箱，/sky-md=Sky Markdown 介绍页，/sky-sql=SkySQL 介绍页
# /fortune=AURELO（Next.js 容器 3502），/fortune-cn=天时历（Next.js 容器 3501）——两应用带 basePath，用 handle 不剥前缀
:80 {
	redir /me /me/ permanent
	redir /sky-tool /sky-tool/ permanent
	redir /sky-md /sky-md/ permanent
	redir /sky-sql /sky-sql/ permanent
	# Next.js basePath 应用自己处理尾斜杠（/fortune/ 会 308 回 /fortune），这里不能再加 redir，否则成环
	@fortune path /fortune /fortune/*
	handle @fortune {
		reverse_proxy localhost:3502
	}
	@fortunecn path /fortune-cn /fortune-cn/*
	handle @fortunecn {
		reverse_proxy localhost:3501
	}
	handle_path /me/* {
		root * /home/code/sky-personal/me
		file_server
	}
	handle_path /sky-tool/* {
		root * /home/code/sky-tool
		file_server
	}
	handle_path /sky-md/* {
		root * /home/code/sky-md
		file_server
	}
	handle_path /sky-sql/* {
		root * /home/code/sky-sql
		file_server
	}
	handle {
		root * /home/code/sky-personal/showcase
		file_server
	}
}

# www 子域名：301 重定向到主域名（备案要求 www 也可访问，Caddy 自动为其签发证书）
www.skyyjj.cn {
	redir https://skyyjj.cn{uri} permanent
}

# 域名（备案通过后自动 HTTPS）：根=作品集，/me=个人主页，/voc=SKG VOC 看板，/sky-tool=Sky 工具箱，/sky-md=Sky Markdown 介绍页，/sky-sql=SkySQL 介绍页
skyyjj.cn {
	redir /me /me/ permanent
	redir /sky-tool /sky-tool/ permanent
	redir /sky-md /sky-md/ permanent
	redir /sky-sql /sky-sql/ permanent
	@fortune path /fortune /fortune/*
	handle @fortune {
		reverse_proxy localhost:3502
	}
	@fortunecn path /fortune-cn /fortune-cn/*
	handle @fortunecn {
		reverse_proxy localhost:3501
	}
	handle_path /me/* {
		root * /home/code/sky-personal/me
		file_server
	}
	handle_path /voc/* {
		reverse_proxy localhost:8050
	}
	handle_path /sky-tool/* {
		root * /home/code/sky-tool
		file_server
	}
	handle_path /sky-md/* {
		root * /home/code/sky-md
		file_server
	}
	handle_path /sky-sql/* {
		root * /home/code/sky-sql
		file_server
	}
	handle {
		root * /home/code/sky-personal/showcase
		file_server
	}
}
